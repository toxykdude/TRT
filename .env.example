# ──────────────────────────────────────────────────────────────────────────
# TRT Clinical Decision Support Dashboard — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All AI/clinical behavior is governed by GOLD.md §2 (the Prime Directive).
# ──────────────────────────────────────────────────────────────────────────

# ── Database (local Postgres on the LXC) ───────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://trt:CHANGE_ME@127.0.0.1:5432/trt?schema=public"

# ── App / Auth ─────────────────────────────────────────────────────────────
# Public URL the app is served on (via Cloudflare Tunnel)
NEXTAUTH_URL="https://trt.powerhousegym.co"
# Random 32+ char secret: `openssl rand -base64 32`
AUTH_SECRET="CHANGE_ME_to_a_long_random_string"
# Sensitive operations (password reset) need a salt; reuse AUTH_SECRET or set separately
NEXTAUTH_SALT="CHANGE_ME"

# ── Google OAuth (optional in foundation pass) ─────────────────────────────
# Create at: Google Cloud Console → APIs & Services → Credentials (OAuth client)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI (stubbed in this pass — real key drops in later) ─────────────────────
# When set, packages/ai will call OpenAI. When empty, deterministic stubs run.
OPENAI_API_KEY=""

# ── Storage ────────────────────────────────────────────────────────────────
# Where uploaded lab files live (private, outside webroot). Absolute path.
UPLOADS_DIR="/var/lib/trt/uploads"

# ── Knowledge base (Layer 1 — deterministic, no model) ──────────────────────
# SQLite DB built by `scripts/build-kb.ts` from the corpus at CORPUS_DIR.
KB_DB_PATH="/var/lib/trt/kb/knowledge.db"
KB_TEXT_DIR="/var/lib/trt/kb/text"
CORPUS_DIR="/var/lib/trt/corpus"
# OCR endpoint for scanned PDFs / images (fallback when pdftotext finds nothing).
OCR_ENDPOINT="https://imagedit.powerhousegym.co/ocr"

# ── Graphiti graph (Layer 2 — MCP; builds with an LLM) ──────────────────────
# URL of the Graphiti MCP server. Empty = graph features disabled (Layer 1 still works).
GRAPHITI_MCP_URL="http://127.0.0.1:8000"
# URL of the LOCAL graph query service (scripts/graph_query_service.py) — the
# primary Layer 2 query path for both the web app and the MCP server.
GRAPH_QUERY_URL="http://127.0.0.1:8001"
# To BUILD the graph, set an LLM key and run scripts/ingest_corpus.py:
#   OPENAI_API_KEY / ANTHROPIC_API_KEY / GOOGLE_API_KEY / GROQ_API_KEY

# ── MCP server (@trt/mcp — AI-model access to the knowledge stack) ───────────
# Streamable HTTP transport (pnpm --filter @trt/mcp start:http). Loopback-only
# by default; set MCP_AUTH_TOKEN before exposing beyond localhost.
MCP_HTTP_HOST="127.0.0.1"
MCP_HTTP_PORT="8002"
MCP_AUTH_TOKEN=""

# ── Node env ───────────────────────────────────────────────────────────────
NODE_ENV="development"
